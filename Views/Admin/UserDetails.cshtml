@model UniManage.Models.ApplicationUser
@{
    ViewData["Title"] = "User Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-person-circle"></i> User Details</h2>
    <a asp-action="Users" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Users
    </a>
</div>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-header text-white" style="background:linear-gradient(135deg,#1e3a5f,#4a90d9);">
        <div class="d-flex align-items-center">
            <div class="rounded-circle bg-white text-primary d-flex align-items-center
                justify-content-center fw-bold me-3"
                 style="width:55px;height:55px;font-size:1.5rem;">
                @Model.FullName[0].ToString().ToUpper()
            </div>
            <div>
                <h5 class="mb-0 text-white">@Model.FullName</h5>
                <small class="text-white-50">@Model.Email</small>
            </div>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-borderless">
            <tr>
                <td class="fw-bold text-muted">Full Name</td>
                <td>@Model.FullName</td>
            </tr>
            <tr>
                <td class="fw-bold text-muted">Email</td>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <td class="fw-bold text-muted">Role</td>
                <td>
                    <span class="badge @(Model.Role == "Admin" ? "bg-danger" :
                                                                                          Model.Role == "Lecturer" ? "bg-success" : "bg-primary") fs-6">
                        @Model.Role
                    </span>
                </td>
            </tr>
            <tr>
                <td class="fw-bold text-muted">Username</td>
                <td>@Model.UserName</td>
            </tr>
            <tr>
                <td class="fw-bold text-muted">Email Confirmed</td>
                <td>
                    @if (Model.EmailConfirmed)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">No</span>
                    }
                </td>
            </tr>
        </table>
    </div>
    <div class="card-footer bg-transparent">
        @if (Model.Role != "Admin")
        {
            <a asp-action="DeleteUser" asp-route-id="@Model.Id"
                   onclick="return confirm('Delete this user? This cannot be undone.')"
                   class="btn btn-danger w-100">
                <i class="bi bi-trash"></i> Delete User
            </a>
        }
    </div>
</div>