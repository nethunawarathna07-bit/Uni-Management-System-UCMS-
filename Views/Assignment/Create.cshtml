@model UniManage.Models.Assignment
@{
    ViewData["Title"] = "Create Assignment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-plus-circle"></i> Create Assignment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="card shadow-sm" style="max-width:750px;">
    <div class="card-header bg-primary text-white fw-bold">
        <i class="bi bi-pencil-square"></i> Assignment Details
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Assignment Title</label>
                <input asp-for="Title" class="form-control"
                       placeholder="e.g. Python Basics: Calculator Program" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Description / Instructions</label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="Write the assignment instructions here..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Deadline</label>
                <input asp-for="Deadline" type="datetime-local" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Course</label>
                <select asp-for="CourseId" class="form-select">
                    <option value="">-- Select Course --</option>
                    @foreach (var course in ViewBag.Courses)
                    {
                        <option value="@course.CourseId">@course.CourseName</option>
                    }
                </select>
            </div>

            <hr />

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-file-earmark-pdf text-danger"></i>
                    Upload Assignment PDF
                    <span class="text-muted fw-normal">(Optional)</span>
                </label>
                <div class="border rounded p-3 bg-light">
                    <input type="file" name="assignmentFile" class="form-control"
                           accept=".pdf" id="assignmentFileInput" />
                    <small class="text-muted mt-1 d-block">
                        <i class="bi bi-info-circle"></i>
                        If you upload a PDF, students will be able to download it.
                        Only PDF files are accepted.
                    </small>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                <i class="bi bi-save"></i> Create Assignment
            </button>
        </form>
    </div>
</div>