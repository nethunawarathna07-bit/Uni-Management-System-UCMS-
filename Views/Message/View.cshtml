@model UniManage.Models.Message
@{
    ViewData["Title"] = "View Message";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-envelope-open"></i> Message</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Inbox
    </a>
</div>

<div class="card shadow-sm" style="max-width:800px;">
    <div class="card-header" style="background:linear-gradient(135deg,#1e3a5f,#4a90d9);">
        <div class="d-flex justify-content-between align-items-center text-white">
            <div>
                <strong>
                    <i class="bi bi-person-circle"></i>
                    From: @Model.Sender?.FullName
                </strong>
                <span class="text-white-50 ms-2">→ To: @Model.Receiver?.FullName</span>
            </div>
            <small>@Model.SentDate.ToString("MMMM dd, yyyy HH:mm")</small>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="bg-light rounded p-4" style="min-height:150px;font-size:1.05rem;line-height:1.7;">
            @Model.Content
        </div>
    </div>
    <div class="card-footer bg-transparent d-flex gap-2">
        @if (Model.SenderId != ViewBag.CurrentUserId.ToString())
        {
            <a asp-action="Reply" asp-route-id="@Model.MessageId"
                   class="btn btn-primary">
                <i class="bi bi-reply"></i> Reply
            </a>
        }
        <a asp-action="Compose" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square"></i> New Message
        </a>
        <a asp-action="Delete" asp-route-id="@Model.MessageId"
               onclick="return confirm('Delete this message?')"
               class="btn btn-outline-danger ms-auto">
            <i class="bi bi-trash"></i> Delete
        </a>
    </div>
</div>