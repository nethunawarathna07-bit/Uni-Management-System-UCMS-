@{
    ViewData["Title"] = "Compose Message";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-pencil-square"></i> Compose Message</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Inbox
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-x-circle"></i> @TempData["Error"]</div>
}

@if (ViewBag.OriginalMessage != null)
{
    <div class="alert alert-secondary mb-3">
        <strong><i class="bi bi-reply"></i> Replying to @ViewBag.OriginalMessage.Sender?.FullName:</strong>
        <p class="mb-0 text-muted small mt-1">@ViewBag.OriginalMessage.Content</p>
    </div>
}

<div class="card shadow-sm" style="max-width:700px;">
    <div class="card-header bg-primary text-white fw-bold">
        <i class="bi bi-envelope"></i> New Message
    </div>
    <div class="card-body">
        <form asp-action="Compose" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">To:</label>
                <select name="receiverId" class="form-select" required>
                    <option value="">-- Select Recipient --</option>
                    @foreach (var u in ViewBag.Users)
                    {
                        bool isPreselected = u.Id == ViewBag.PreselectedReceiverId?.ToString();
                        <option value="@u.Id" selected="@isPreselected">
                            @u.FullName (@u.Role)
                        </option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Message:</label>
                <textarea name="content" class="form-control" rows="7"
                          placeholder="Write your message here..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-send"></i> Send Message
            </button>
        </form>
    </div>
</div>