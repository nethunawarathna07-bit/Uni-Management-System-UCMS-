@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-bar-chart"></i> Reports & Analytics</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-bar-chart-fill fs-1 text-primary mb-3 d-block"></i>
                <h5 class="fw-bold">Course Popularity</h5>
                <p class="text-muted small">Enrollment statistics and fill rates for all courses</p>
                <div class="d-grid gap-2">
                    <a asp-action="CoursePopularityReport" class="btn btn-outline-primary">
                        <i class="bi bi-eye"></i> View Report
                    </a>
                    <a asp-action="DownloadCoursePopularity" class="btn btn-primary">
                        <i class="bi bi-file-earmark-pdf"></i> Download PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-person-check-fill fs-1 text-success mb-3 d-block"></i>
                <h5 class="fw-bold">Student Performance</h5>
                <p class="text-muted small">Average grades and performance ratings per student</p>
                <div class="d-grid gap-2">
                    <a asp-action="StudentPerformanceReport" class="btn btn-outline-success">
                        <i class="bi bi-eye"></i> View Report
                    </a>
                    <a asp-action="DownloadStudentPerformance" class="btn btn-success">
                        <i class="bi bi-file-earmark-pdf"></i> Download PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-person-badge-fill fs-1 text-warning mb-3 d-block"></i>
                <h5 class="fw-bold">Workload Analysis</h5>
                <p class="text-muted small">Lecturer workload, courses and pending grading</p>
                <div class="d-grid gap-2">
                    <a asp-action="WorkloadReport" class="btn btn-outline-warning">
                        <i class="bi bi-eye"></i> View Report
                    </a>
                    <a asp-action="DownloadWorkload" class="btn btn-warning">
                        <i class="bi bi-file-earmark-pdf"></i> Download PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card blue p-3 text-center">
            <i class="bi bi-people fs-1 text-primary"></i>
            <h3 class="fw-bold">@ViewBag.TotalStudents</h3>
            <p class="text-muted mb-0">Total Students</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card green p-3 text-center">
            <i class="bi bi-book fs-1 text-success"></i>
            <h3 class="fw-bold">@ViewBag.TotalCourses</h3>
            <p class="text-muted mb-0">Total Courses</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card orange p-3 text-center">
            <i class="bi bi-upload fs-1 text-warning"></i>
            <h3 class="fw-bold">@ViewBag.TotalSubmissions</h3>
            <p class="text-muted mb-0">Total Submissions</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card purple p-3 text-center">
            <i class="bi bi-star fs-1"></i>
            <h3 class="fw-bold">@ViewBag.GradedSubmissions</h3>
            <p class="text-muted mb-0">Graded</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-bar-chart"></i> Course Enrollment Statistics
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead><tr><th>Course</th><th>Lecturer</th><th>Enrolled</th><th>Fill %</th></tr></thead>
                    <tbody>
                        @foreach (var stat in ViewBag.CourseStats)
                        {
                            var pct = stat.MaxStudents > 0
                                ? (int)((double)stat.EnrollmentCount / stat.MaxStudents * 100) : 0;
                            <tr>
                                <td>@stat.CourseName</td>
                                <td>@stat.LecturerName</td>
                                <td>@stat.EnrollmentCount / @stat.MaxStudents</td>
                                <td>
                                    <div class="progress" style="height:20px;">
                                        <div class="progress-bar
                                            @(pct >= 90 ? "bg-danger" : pct >= 60 ? "bg-warning" : "bg-success")"
                                             style="width:@pct%">
                                            @pct%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-person-check"></i> Student Performance
            </div>
            <div class="card-body">
                @if (((IEnumerable<dynamic>)ViewBag.StudentPerformance).Any())
                {
                    <table class="table table-hover">
                        <thead><tr><th>Student</th><th>Average Grade</th><th>Performance</th></tr></thead>
                        <tbody>
                            @foreach (var perf in ViewBag.StudentPerformance)
                            {
                                var avg = (double)perf.AverageGrade;
                                <tr>
                                    <td>@perf.StudentName</td>
                                    <td><strong>@avg.ToString("F1")/100</strong></td>
                                    <td>
                                        <span class="badge
                                            @(avg >= 70 ? "bg-success" : avg >= 50 ? "bg-warning" : "bg-danger")">
                                            @(avg >= 70 ? "Good" : avg >= 50 ? "Average" : "Needs Improvement")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center py-3">No grades recorded yet.</p>
                }
            </div>
        </div>
    </div>
</div>