<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniManage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
            body { background-color: #f0f4f8; }
            .navbar { background: linear-gradient(135deg, #1e3a5f, #4a90d9); }
            .navbar-brand, .nav-link { color: white !important; font-weight: 600; }
            .sidebar { background: linear-gradient(180deg, #1e3a5f, #2c5282); min-height: 100vh; padding-top: 20px; }
            .sidebar .nav-link { color: #a0c4e8 !important; padding: 12px 20px; border-radius: 8px; margin: 2px 10px; }
            .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.2); color: white !important; }
            .sidebar .nav-link i { margin-right: 10px; }
            .card { border: none; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); }
            .card-header { border-radius: 15px 15px 0 0 !important; font-weight: 700; }
            .btn-primary { background: linear-gradient(135deg, #1e3a5f, #4a90d9); border: none; }
            .btn-primary:hover { background: linear-gradient(135deg, #4a90d9, #1e3a5f); }
            .stat-card { border-left: 5px solid; }
            .stat-card.blue { border-color: #4a90d9; }
            .stat-card.green { border-color: #28a745; }
            .stat-card.orange { border-color: #fd7e14; }
            .stat-card.purple { border-color: #6f42c1; }
    </style>
</head>
<body>
    @if (User.Identity.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" href="#"><i class="bi bi-mortarboard-fill"></i> UniManage</a>
                <div class="ms-auto d-flex align-items-center">
                    <span class="text-white me-3"><i class="bi bi-person-circle"></i> @User.Identity.Name</span>
                    <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Logout</a>
                </div>
            </div>
        </nav>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-2 sidebar">
                    @await Html.PartialAsync("_Sidebar")
                </div>
                <div class="col-md-10 p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>