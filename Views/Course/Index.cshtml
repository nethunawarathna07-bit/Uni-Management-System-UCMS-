@model List<UniManage.Models.Course>
@{
    ViewData["Title"] = "All Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-book"></i> All Courses</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Course
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Course Name</th>
                    <th>Credits</th>
                    <th>Max Students</th>
                    <th>Enrolled</th>
                    <th>Lecturer</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td><strong>@course.CourseName</strong><br /><small class="text-muted">@course.Description</small></td>
                        <td><span class="badge bg-primary">@course.Credits credits</span></td>
                        <td>@course.MaxStudents</td>
                        <td>
                            <span class="badge @(course.Enrollments.Count >= course.MaxStudents ? "bg-danger" : "bg-success")">
                                @course.Enrollments.Count / @course.MaxStudents
                            </span>
                        </td>
                        <td>@course.Lecturer?.FullName</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@course.CourseId" class="btn btn-sm btn-info text-white">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@course.CourseId" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@course.CourseId"
                                   onclick="return confirm('Are you sure you want to delete this course?')"
                                   class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>