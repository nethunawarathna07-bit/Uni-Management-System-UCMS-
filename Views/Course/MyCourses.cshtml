@model List<UniManage.Models.Course>
@{
    ViewData["Title"] = "My Courses";
}

<h2 class="fw-bold text-primary mb-4"><i class="bi bi-journal-text"></i> My Courses</h2>

<div class="row g-4">
    @foreach (var course in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-book"></i> @course.CourseName
                </div>
                <div class="card-body">
                    <p class="text-muted">@course.Description</p>
                    <div class="d-flex justify-content-between">
                        <span class="badge bg-info">@course.Credits Credits</span>
                        <span class="badge bg-success">@course.Enrollments.Count / @course.MaxStudents Students</span>
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@course.CourseId" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-eye"></i> View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>